      "source": [
        "Q1 = df[\"total_amount\"].quantile(0.25)\n",
        "Q3 = df[\"total_amount\"].quantile(0.75)\n",
        "IQR = Q3-Q1\n",
        "lower_bound = Q1 - 1.5*IQR\n",
        "upper_bound = Q3 + 1.5*IQR"
      ],
      "metadata": {
        "id": "t0McvK4MAzEK"
      },
      "execution_count": 32,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "outliers = df[\n",
        "    (df[\"total_amount\"] < lower_bound) |\n",
        "    (df[\"total_amount\"] > upper_bound)\n",
        "]\n",
        "print(len(outliers))"
